# Frontend production environment variables
# Use this file when frontend and backend are deployed on different domains.
# Vite will inline these values at build time.

# Public API base URL used by the frontend app in production.
# Example:
#   Frontend: https://app.example.com
#   Backend : https://api.example.com
VITE_API_URL=https://api.example.com/api

# Optional: if you build/run preview with Vite proxy in a server-like setup,
# you can point proxy target here. Usually not required for static hosting.
# VITE_BACKEND_TARGET=https://api.example.com
